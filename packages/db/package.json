    "provision": "node dist/provision-cli.js"
  },
  "dependencies": {
    "@clockwork/activity-log": "workspace:*",
    "@clockwork/agentfolio-core": "workspace:*",
    "@clockwork/config": "workspace:*",
    "@clockwork/marketing": "workspace:*",
    "@clockwork/tenants": "workspace:*",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10"
  }
}
